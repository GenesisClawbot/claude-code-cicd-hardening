{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claude Agent Output",
  "description": "Expected output format for Claude Code CI agent",
  "type": "object",
  "required": ["status"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ok", "error", "partial"]
    },
    "changes_reviewed": {
      "type": "integer",
      "minimum": 0
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "description"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "description": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "line": {
            "type": "integer"
          }
        }
      }
    },
    "summary": {
      "type": "string"
    },
    "error": {
      "type": "string"
    },
    "warning": {
      "type": "string"
    }
  }
}
